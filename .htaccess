RewriteEngine On

# Remove .php extension from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Clean URL routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^about/?$ about.php [NC,L]
RewriteRule ^products/?$ products/index.php [NC,L]
RewriteRule ^products/profiles/?$ products/profiles.php [NC,L]
RewriteRule ^products/glass/?$ products/glass.php [NC,L]
RewriteRule ^gallery/?$ gallery.php [NC,L]
RewriteRule ^contact/?$ contact.php [NC,L]
RewriteRule ^calculator/?$ calculator.php [NC,L]

# Authentication routes
RewriteRule ^auth/login/?$ auth/login.php [NC,L]
RewriteRule ^auth/register/?$ auth/register.php [NC,L]
RewriteRule ^auth/verify/?$ auth/verify.php [NC,L]
RewriteRule ^auth/forgot-password/?$ auth/forgot-password.php [NC,L]

# Admin routes
RewriteRule ^admin/?$ admin/index.php [NC,L]
RewriteRule ^admin/([a-zA-Z0-9_-]+)/?$ admin/$1/index.php [NC,L]

# Sales routes
RewriteRule ^sales/?$ sales/index.php [NC,L]
RewriteRule ^sales/([a-zA-Z0-9_-]+)/?$ sales/$1/index.php [NC,L]

# Customer routes
RewriteRule ^customer/?$ customer/index.php [NC,L]
RewriteRule ^customer/([a-zA-Z0-9_-]+)/?$ customer/$1/index.php [NC,L]

# API routes
RewriteRule ^api/([a-zA-Z0-9_-]+)/?$ api/$1/index.php [NC,L]
RewriteRule ^api/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ api/$1/$2.php [NC,L]

# Security headers
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options DENY
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy strict-origin-when-cross-origin

# Cache control for assets
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg)$">
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    Header set Cache-Control "public, immutable"
</FilesMatch>

# Prevent access to sensitive files
<FilesMatch "\.(env|log|sql|conf)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Prevent access to sensitive directories
RedirectMatch 404 /\.(git|svn|htaccess)
RedirectMatch 404 /(config|includes|logs|storage)/.*

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>